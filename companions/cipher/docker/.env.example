# Cipher Code Kraken — Environment Configuration
# Copy this to .env and fill in your values

# ── Required ────────────────────────────────────────────────────────────
# None! Cipher runs fully local with zero API keys.

# ── Optional (Frontier Supervisor) ──────────────────────────────────────
# Enables escalation to GPT-5.4 for complex tasks.
# Get a key from https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-v1-...

# Or use OpenAI directly:
# OPENAI_API_KEY=sk-...

# ── Optional (Memory) ──────────────────────────────────────────────────
# Enables persistent long-term memory across sessions.
# Get a key from https://supermemory.ai
# SUPERMEMORY_API_KEY=sm-...

# ── Optional (kr8tiv Integration) ──────────────────────────────────────
# Mission Control for prompt evolution + governance
# MISSION_CONTROL_URL=https://mc.kr8tiv.ai
# OPENCLAW_GATEWAY_TOKEN=...

# ── Advanced ────────────────────────────────────────────────────────────
# OLLAMA_HOST=http://127.0.0.1
# OLLAMA_PORT=11434
# CIPHER_MODEL=kin-cipher
# CIPHER_PORT=3333
# FRONTIER_MODEL=gpt-5.4
# ESCALATION_LEVEL=medium
# LOG_LEVEL=info
